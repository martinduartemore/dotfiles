# zsh exports

# make vim the default editor
export EDITOR="vim"
export VISUAL="${EDITOR}"

# History settings (zsh)
HISTSIZE=10000
SAVEHIST=10000
# enable timestamped history in a readable ISO-like format
HIST_STAMPS="yyyy-mm-dd"

# zsh history & behavior options
setopt INC_APPEND_HISTORY    # append history immediately, rather than waiting for shell exit
setopt SHARE_HISTORY         # share history across all sessions
setopt HIST_IGNORE_ALL_DUPS  # don't record duplicate entries
setopt HIST_REDUCE_BLANKS    # remove superfluous blanks in history entries

# Ignore trivial commands in history
typeset -g HISTIGNORE="ls:cd"
